generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id           String    @id @default(uuid())
  name         String
  email        String    @unique
  username     String    @unique
  passwordHash String
  isActive     Boolean   @default(true)
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  lastLoginAt  DateTime?

  userRoles UserRole[]
  sessions  Session[]
  auditLogs AuditLog[]

  @@index([isActive])
}

model Role {
  id          String   @id @default(uuid())
  key         String   @unique
  name        String   @unique
  description String?
  isActive    Boolean  @default(true)
  system      Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  userRoles       UserRole[]
  rolePermissions RolePermission[]

  @@index([isActive])
}

model Permission {
  id          String   @id @default(uuid())
  key         String   @unique
  label       String
  group       String
  description String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  rolePermissions RolePermission[]

  @@index([group])
}

model UserRole {
  userId String
  roleId String

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  role Role @relation(fields: [roleId], references: [id], onDelete: Cascade)

  @@id([userId, roleId])
  @@index([roleId])
}

model RolePermission {
  roleId       String
  permissionId String

  role       Role       @relation(fields: [roleId], references: [id], onDelete: Cascade)
  permission Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  @@id([roleId, permissionId])
  @@index([permissionId])
}

model Session {
  id        String    @id @default(uuid())
  userId    String
  expiresAt DateTime
  revokedAt DateTime?
  ipAddress String?
  userAgent String?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  user          User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  refreshTokens RefreshToken[]

  @@index([userId])
  @@index([expiresAt])
}

model RefreshToken {
  id        String    @id @default(uuid())
  sessionId String
  tokenHash String
  expiresAt DateTime
  revokedAt DateTime?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  session Session @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  @@index([sessionId])
  @@index([expiresAt])
}

model AuditLog {
  id                 String   @id @default(uuid())
  userId             String?
  username           String?
  action             String
  module             String?
  stage              String?
  internalTreeNumber String?
  oldValue           Json?
  newValue           Json?
  notes              String?
  ipAddress          String?
  userAgent          String?
  createdAt          DateTime @default(now())

  user User? @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([action])
  @@index([module])
  @@index([stage])
  @@index([internalTreeNumber])
  @@index([createdAt])
}

model InternalTreeSequence {
  id                   String   @id @default("global")
  currentPrefix        String   @default("A")
  currentAlphabetIndex Int      @default(0)
  currentNumber        Int      @default(0)
  currentCycle         Int      @default(0)
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt
}

model WaxEntry {
  id                   String    @id @default(uuid())
  internalTreeNumber   String    @unique
  internalTreePrefix   String
  internalTreeSequence Int
  internalTreeCycle    Int       @default(0)
  vendorCustomerName   String    @default("")
  date                 DateTime?
  waxInvoiceNo         String    @default("")
  customerVendorTreeNo String    @default("")
  metalKt              String    @default("")
  color                String    @default("")
  waxWeight            Decimal?  @db.Decimal(12, 3)
  isRush               Boolean   @default(false)
  createdByUserId      String?
  createdByUsername    String?
  updatedByUserId      String?
  updatedByUsername    String?
  createdAt            DateTime  @default(now())
  updatedAt            DateTime  @updatedAt
  deletedAt            DateTime?

  castingWorkflow CastingWorkflow?

  @@index([internalTreePrefix, internalTreeSequence])
  @@index([deletedAt])
  @@index([createdAt])
}

// Casting workflow — one per wax entry
model CastingWorkflow {
  id                 String    @id @default(uuid())
  waxEntryId         String    @unique
  internalTreeNumber String    @unique
  stage              String    @default("Awaiting Metal")
  notes              String    @default("")

  // Metal issue
  metalIssue         Json?

  // Casting stage
  castingIssue       Json?
  castingVerification Json?

  // QC stage
  qcVerification     Json?

  // Final posting
  finalOrderPosted   Boolean   @default(false)
  finalStatus        String?
  removedFromBoard   Boolean   @default(false)
  isDamaged          Boolean   @default(false)
  damagedTree        Json?

  // Inventory posting tracking
  inventoryLedgerIds Json?

  updatedByUserId    String?
  updatedByUsername  String?
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt

  waxEntry WaxEntry @relation(fields: [waxEntryId], references: [id], onDelete: Cascade)

  @@index([stage])
  @@index([isDamaged])
  @@index([finalOrderPosted])
  @@index([createdAt])
}

// Metal Receiving entries
model MetalReceiving {
  id                 String    @id @default(uuid())
  receivingDate      DateTime
  vendor             String    @default("")
  invoiceNo          String    @default("")
  metalKt            String    @default("")
  color              String    @default("")
  metalSource        String    @default("")
  grossWeight        Decimal?  @db.Decimal(12, 3)
  netWeight          Decimal?  @db.Decimal(12, 3)
  notes              String    @default("")
  createdByUserId    String?
  createdByUsername  String?
  updatedByUserId    String?
  updatedByUsername  String?
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt
  deletedAt          DateTime?

  @@index([receivingDate])
  @@index([deletedAt])
}

// Inventory Ledger — one entry per posting action
model InventoryLedger {
  id                 String    @id @default(uuid())
  internalTreeNumber String
  entryType          String    // "metal_issue", "casting_return", "final_post"
  metalKt            String    @default("")
  color              String    @default("")
  metalSource        String    @default("")

  // Weight fields (all optional, based on entry type)
  fineGoldWeight     Decimal?  @db.Decimal(12, 3)
  alloyWeight        Decimal?  @db.Decimal(12, 3)
  recycledWeight     Decimal?  @db.Decimal(12, 3)
  issuedWeight       Decimal?  @db.Decimal(12, 3)
  returnedWeight     Decimal?  @db.Decimal(12, 3)
  finishedWeight     Decimal?  @db.Decimal(12, 3)
  spruWeight         Decimal?  @db.Decimal(12, 3)
  scrapWeight        Decimal?  @db.Decimal(12, 3)

  isDuplicate        Boolean   @default(false)
  postedByUserId     String?
  postedByUsername   String?
  postedAt           DateTime  @default(now())
  notes              String    @default("")
  rawPayload         Json?

  @@index([internalTreeNumber])
  @@index([entryType])
  @@index([postedAt])
}
